{
  "document": {
    "color": "#839496",
    "margin": 2
  },
  "heading": {
    "bold": true,
    "color": "#268BD2"
  },
  "h1": {
    "prefix": "# ",
    "bold": true,
    "color": "#268BD2"
  },
  "h2": {
    "prefix": "## ",
    "bold": true,
    "color": "#2AA198"
  },
  "h3": {
    "prefix": "### ",
    "bold": true,
    "color": "#859900"
  },
  "code": {
    "color": "#B58900"
  },
  "code_block": {
    "color": "#B58900",
    "margin": 2,
    "chroma": {
      "theme": "solarized-dark"
    }
  },
  "link": {
    "color": "#2AA198",
    "underline": true
  },
  "link_text": {
    "color": "#6C71C4",
    "bold": true
  },
  "strong": {
    "bold": true,
    "color": "#CB4B16"
  },
  "emph": {
    "italic": true,
    "color": "#D33682"
  },
  "list": {
    "level_indent": 2
  },
  "item": {
    "block_prefix": "\u2022 "
  }
}
