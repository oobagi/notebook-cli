{
  "document": {
    "color": "#EBDBB2",
    "margin": 2
  },
  "heading": {
    "bold": true,
    "color": "#FE8019"
  },
  "h1": {
    "prefix": "# ",
    "bold": true,
    "color": "#FE8019"
  },
  "h2": {
    "prefix": "## ",
    "bold": true,
    "color": "#8EC07C"
  },
  "h3": {
    "prefix": "### ",
    "bold": true,
    "color": "#B8BB26"
  },
  "code": {
    "color": "#FABD2F"
  },
  "code_block": {
    "color": "#FABD2F",
    "margin": 2,
    "chroma": {
      "theme": "gruvbox"
    }
  },
  "link": {
    "color": "#83A598",
    "underline": true
  },
  "link_text": {
    "color": "#D3869B",
    "bold": true
  },
  "strong": {
    "bold": true,
    "color": "#FB4934"
  },
  "emph": {
    "italic": true,
    "color": "#D3869B"
  },
  "list": {
    "level_indent": 2
  },
  "item": {
    "block_prefix": "\u2022 "
  }
}
