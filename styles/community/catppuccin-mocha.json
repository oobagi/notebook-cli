{
  "document": {
    "color": "#CDD6F4",
    "margin": 2
  },
  "heading": {
    "bold": true,
    "color": "#89B4FA"
  },
  "h1": {
    "prefix": "# ",
    "bold": true,
    "color": "#89B4FA"
  },
  "h2": {
    "prefix": "## ",
    "bold": true,
    "color": "#CBA6F7"
  },
  "h3": {
    "prefix": "### ",
    "bold": true,
    "color": "#A6E3A1"
  },
  "code": {
    "color": "#F9E2AF"
  },
  "code_block": {
    "color": "#F9E2AF",
    "margin": 2,
    "chroma": {
      "theme": "catppuccin-mocha"
    }
  },
  "link": {
    "color": "#89DCEB",
    "underline": true
  },
  "link_text": {
    "color": "#F5C2E7",
    "bold": true
  },
  "strong": {
    "bold": true,
    "color": "#F38BA8"
  },
  "emph": {
    "italic": true,
    "color": "#F5C2E7"
  },
  "list": {
    "level_indent": 2
  },
  "item": {
    "block_prefix": "\u2022 "
  }
}
